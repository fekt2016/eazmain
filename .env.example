# Saiisai Buyer App (saiisaiweb) – Environment Variables
# Copy to .env and fill in values

# Required: Backend API base URL (no trailing slash)
# Dev: http://localhost:4000/api/v1
# Prod: https://api.saiisai.com/api/v1
VITE_API_BASE_URL=
VITE_API_URL=

# Optional: Frontend canonical URL (defaults to window.location.origin)
VITE_FRONTEND_URL=

# Optional: Seller dashboard URL (homepage promo CTA; default https://seller.saiisai.com)
# VITE_SELLER_APP_URL=http://localhost:5175

# Optional: API timeout in ms (default: 60000)
VITE_API_TIMEOUT=60000

# Optional: Analytics / tracking
# VITE_GA_MEASUREMENT_ID=
# VITE_FB_PIXEL_ID=
# VITE_TIKTOK_PIXEL_ID=

# Optional: Google Maps (for address autocomplete, etc.)
# VITE_GOOGLE_MAPS_API_KEY=

# Optional: Checkout “Bank transfer” details (defaults in appConfig if unset)
# VITE_CHECKOUT_BANK_NAME=CBG Bank
# VITE_CHECKOUT_BANK_BRANCH=Nima Branch
# VITE_CHECKOUT_BANK_ACCOUNT_NAME=EasyworldPc
# VITE_CHECKOUT_BANK_ACCOUNT_NUMBER=
# VITE_CHECKOUT_BANK_REFERENCE=Your Order Number
#
# Buyer mobile (saiisai) uses the same values with Expo’s prefix — see saiisai/.env.example
